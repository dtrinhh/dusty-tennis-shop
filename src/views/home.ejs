<%- include('partials/header') %>
<main>
    <!-- Greeting -->
    <div>
        <h1>Welcome to Dusty Tennis Shop</h1>
        <p>Centerhub for all your tennis string needs.</p>
        <a href="/products">Shop All Strings</a>
    </div>

    <!-- Newest strings section -->
    <div>
        <h2>New Arrivals</h2>
        <div>
            <% newestStrings.forEach(string => { %>
                <div>
                    <h3><%= string.brand %> <%= string.name %></h3>
                    <p>Material: <%= string.material %></p>
                    <p>Price: $<%= string.price %></p>
                    <a href="/products/<%= string.id %>">View Details</a>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Random strings in "Try Out These Strings Next" section -->
    <div>
        <h2>Try Out These Strings Next</h2>
        <div>
            <% randomStrings.forEach(string => { %>
                <div>
                    <h3><%= string.brand %> <%= string.name %></h3>
                    <p>Material: <%= string.material %></p>
                    <p>Price: $<%= string.price %></p>
                    <a href="/products/<%= string.id %>">View Details</a>
                </div>
            <% }) %>
        </div>
    </div>
</main>
<%- include('partials/footer') %>