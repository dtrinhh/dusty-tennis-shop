<%- include('partials/header') %>
<main>
    <h1>Our Strings</h1>

    <!-- Sorting options -->
    <div>
        <span>Sort by: </span>
        <a href="/products?sort=brand">Brand</a> |
        <a href="/products?sort=name">Name</a> |
        <a href="/products?sort=price">Price</a>
    </div>

    <!-- Product list -->
    <div>
        <% if (strings.length === 0) { %>
            <p>No strings found.</p>
        <% } else { %>
            <% strings.forEach(string => { %>
                <div>
                    <h2><%= string.brand %> <%= string.name %></h2>
                    <p>Material: <%= string.material %></p>
                    <p>Color: <%= string.color %></p>
                    <p>Price: $<%= string.price %></p>
                    <p>Description: <%= string.description %></p>
                    <a href="/products/<%= string.id %>">View Details</a>
                </div>
            <% }) %>
        <% } %>
    </div>
</main>
<%- include('partials/footer') %>