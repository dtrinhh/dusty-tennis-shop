<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    
    <% if (NODE_ENV.includes('dev')) { %>
        <script>
            // Get the current hostname and port from the browser
            const host = window.location.hostname;
            const currentPort = window.location.port;

            // Calculate WebSocket port (current port + 1)
            const wsPort = currentPort ? (parseInt(currentPort) + 1) : 3001;

            // Create WebSocket connection using dynamic hostname and port
            const ws = new WebSocket(`ws://${host}:${wsPort}`);
            ws.onclose = () => {
                setTimeout(() => location.reload(), 2000);
            };
        </script>
    <% } %>
</head>
<body>
    <header>
        <nav>
            <ul>
                <!-- Always visible links -->
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/products">Products</a></li>
                <li><a href="/contact">Contact</a></li>

                <!-- Only visible when logged in -->
                <% if (isLoggedIn && user) { %>
                    <% if (user.roleName === 'admin') { %>
                        <li><a href="/admin">Admin Dashboard</a></li>
                    <% } %>
                    <li><a href="/account"><%= user.name %></a></li>
                    <li><a href="/logout">Logout</a></li>
                <!-- Only visible when NOT logged in -->
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register">Register</a></li>
                <% } %>
            </ul>
        </nav>
    </header>

    <!-- Flash Messages -->
    <% 
        const errors = flash('error');
        const successes = flash('success'); 
    %>

    <% if (errors.length > 0) { %>
        <ul>
            <% errors.forEach(error => { %>
                <li><%= error %></li>
            <% }) %>
        </ul>
    <% } %>
    <% if (successes.length > 0) { %>
        <ul>
            <% successes.forEach(success => { %>
                <li><%= success %></li>
            <% }) %>
        </ul>
    <% } %>