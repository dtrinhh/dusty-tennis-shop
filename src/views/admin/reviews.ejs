<%- include('../partials/header') %>
<main>
    <h1>Manage Reviews</h1>
    <a href="/admin">← Back to Admin Dashboard</a>

    <% if (reviews.length === 0) { %>
        <p>No reviews yet.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Reviewer</th>
                    <th>Product</th>
                    <th>Rating</th>
                    <th>Review</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% reviews.forEach(review => { %>
                    <tr>
                        <td><%= review.reviewerName %></td>
                        <td>
                            <a href="/products/<%= review.stringId %>">
                                <%= review.stringBrand %> <%= review.stringName %>
                            </a>
                        </td>
                        <td><%= review.rating %> / 5</td>
                        <td><%= review.reviewText %></td>
                        <td><%= review.createdAt.toLocaleDateString() %></td>
                        <td>
                            <form action="/admin/reviews/<%= review.id %>/delete" method="POST">
                                <button type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</main>
<%- include('../partials/footer') %>