<%- include('../partials/header') %>
<main>
    <h1>Manage Users</h1>
    <a href="/admin">← Back to Admin Dashboard</a>

    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.name %></td>
                    <td><%= user.email %></td>
                    <td><%= user.roleName %></td>
                    <td><%= user.createdAt.toLocaleDateString() %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</main>
<%- include('../partials/footer') %>